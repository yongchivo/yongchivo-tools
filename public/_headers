# Security headers for every response, applied by the Workers assets runtime.
# CSP allows 'unsafe-inline' for script-src and style-src because Astro 5 renders
# first-party scripts inline and inlines small stylesheets — this keeps the
# site's own JS/CSS working. The stricter directives (default/base-uri/
# form-action/frame-ancestors/object-src) still block the high-value attacks:
# framing/clickjacking, base-tag and form hijacking, plugins, and off-origin
# loads. Tightening script-src to nonces/hashes is a possible follow-up.
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; object-src 'none'; img-src 'self' data:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self'
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=(), payment=(), usb=()
