---
import { languages, getLocalizedPath, useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;
const homePath = lang === 'es' ? '/es/' : '/';
---

<header class="border-b border-brand-border bg-brand-surface/60 backdrop-blur">
  <div class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-4">
    <a href={homePath} class="flex items-center gap-2 font-semibold tracking-tight">
      <span
        class="inline-block h-2.5 w-2.5 rounded-full bg-gradient-to-r from-brand-magenta to-brand-cyan"
        aria-hidden="true"></span>
      <span class="text-brand-text">Yongchivo <span class="text-brand-cyan">Tools</span></span>
    </a>

    <nav class="flex items-center gap-4 text-sm" aria-label="Main">
      <a
        href="https://yongchivo.com"
        target="_blank"
        rel="noopener"
        class="hidden text-brand-muted transition-colors hover:text-brand-cyan sm:inline"
      >
        {t('nav.yongchivo')}
      </a>
      <a
        href="https://yongchivo.com/phv-prep-uk"
        target="_blank"
        rel="noopener"
        class="hidden text-brand-muted transition-colors hover:text-brand-cyan sm:inline"
      >
        {t('nav.phvprep')}
      </a>

      <div
        class="flex items-center overflow-hidden rounded-md border border-brand-border text-xs"
        aria-label="Language"
      >
        {
          (Object.keys(languages) as Lang[]).map((code) => (
            <a
              href={getLocalizedPath(currentPath, code)}
              class:list={[
                'px-2.5 py-1.5 font-medium uppercase transition-colors',
                code === lang
                  ? 'bg-brand-purple/20 text-brand-purple'
                  : 'text-brand-muted hover:text-brand-text',
              ]}
              aria-current={code === lang ? 'true' : undefined}
            >
              {code}
            </a>
          ))
        }
      </div>
    </nav>
  </div>
</header>
