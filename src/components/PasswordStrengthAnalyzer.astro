---
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const checklist = [
  { id: 'ps-chk-lower', label: t('pwstr.chkLower') },
  { id: 'ps-chk-upper', label: t('pwstr.chkUpper') },
  { id: 'ps-chk-digit', label: t('pwstr.chkDigit') },
  { id: 'ps-chk-symbol', label: t('pwstr.chkSymbol') },
  { id: 'ps-chk-length', label: t('pwstr.chkLength') },
];
---

<div
  id="pwstrength"
  class="max-w-2xl rounded-xl border border-brand-border bg-brand-surface p-5 sm:p-6"
  data-label-show={t('pwstr.show')}
  data-label-hide={t('pwstr.hide')}
  data-r0={t('pwstr.r0')}
  data-r1={t('pwstr.r1')}
  data-r2={t('pwstr.r2')}
  data-r3={t('pwstr.r3')}
  data-r4={t('pwstr.r4')}
  data-t-instant={t('pwstr.timeInstant')}
  data-t-seconds={t('pwstr.timeSeconds')}
  data-t-minutes={t('pwstr.timeMinutes')}
  data-t-hours={t('pwstr.timeHours')}
  data-t-days={t('pwstr.timeDays')}
  data-t-years={t('pwstr.timeYears')}
  data-t-centuries={t('pwstr.timeCenturies')}
  data-w-common={t('pwstr.warnCommon')}
  data-w-variant={t('pwstr.warnVariant')}
  data-w-seq={t('pwstr.warnSeq')}
  data-w-rep={t('pwstr.warnRep')}
  data-w-key={t('pwstr.warnKey')}
>
  <label for="ps-input" class="mb-1.5 block text-sm">{t('pwstr.inputLabel')}</label>
  <div class="flex flex-col gap-2 sm:flex-row">
    <input
      id="ps-input"
      type="password"
      autocomplete="new-password"
      autocapitalize="off"
      spellcheck="false"
      class="min-w-0 flex-1 rounded-lg border border-brand-border bg-brand-bg px-3 py-2.5 font-mono text-sm text-brand-cyan focus:border-brand-purple focus:outline-none"
    />
    <button
      id="ps-toggle"
      type="button"
      class="rounded-lg border border-brand-border px-4 py-2.5 text-sm font-medium text-brand-muted transition-colors hover:border-brand-cyan/60 hover:text-brand-cyan"
    >
      {t('pwstr.show')}
    </button>
  </div>
  <p class="mt-1.5 text-xs text-brand-cyan">{t('pwstr.privacyNote')}</p>

  <div id="ps-results" class="mt-5 hidden border-t border-brand-border pt-5" aria-live="polite">
    <div class="h-1.5 overflow-hidden rounded-full bg-brand-border">
      <div id="ps-meter" class="h-full rounded-full transition-all duration-300"></div>
    </div>
    <p class="mt-1.5 text-sm text-brand-muted">
      {t('pwstr.strengthLabel')}: <span id="ps-rating" class="font-medium text-brand-text"></span>
    </p>

    <div class="mt-4">
      <p class="text-xs text-brand-muted">{t('pwstr.timeLabel')}</p>
      <p id="ps-time" class="mt-0.5 font-mono text-lg text-brand-cyan"></p>
      <p class="mt-1 text-xs text-brand-muted">{t('pwstr.timeAssumption')}</p>
    </div>

    <ul id="ps-warnings" class="mt-4 hidden space-y-1 text-sm" role="alert"></ul>

    <ul class="mt-5 grid gap-2 sm:grid-cols-2">
      {
        checklist.map((item) => (
          <li id={item.id} class="flex items-center gap-2 text-sm text-brand-muted">
            <span class="ps-mark w-4 text-center" aria-hidden="true">
              ✗
            </span>
            {item.label}
          </li>
        ))
      }
    </ul>
  </div>
</div>

<script>
  const root = document.getElementById('pwstrength');
  if (root) {
    const $ = (id: string) => document.getElementById(id)!;
    const input = $('ps-input') as HTMLInputElement;
    const toggle = $('ps-toggle') as HTMLButtonElement;
    const results = $('ps-results');
    const meter = $('ps-meter') as HTMLElement;
    const ratingEl = $('ps-rating');
    const timeEl = $('ps-time');
    const warningsEl = $('ps-warnings');

    // ~230 of the most common leaked passwords (top of rockyou/HIBP-style
    // lists, plus frequent Spanish entries). ~3 KB — checked locally.
    const COMMON = new Set([
      '123456','password','123456789','12345678','12345','1234567','qwerty','abc123','111111','123123',
      '1234567890','000000','1234','iloveyou','1q2w3e4r','qwertyuiop','monkey','dragon','654321','letmein',
      'football','shadow','master','666666','qwerty123','1qaz2wsx','baseball','superman','michael','sunshine',
      'princess','starwars','121212','charlie','aa123456','donald','password1','password123','welcome','admin',
      'root','user','test','guest','login','hello','freedom','whatever','trustno1','batman',
      'zaq12wsx','qazwsx','mustang','jordan','harley','ranger','buster','thomas','robert','soccer',
      'hockey','killer','george','andrew','daniel','joshua','matthew','david','maggie','jessica',
      'amanda','jennifer','michelle','nicole','hannah','ashley','taylor','summer','pepper','ginger',
      'cookie','peanut','morgan','cameron','justin','anthony','austin','secret','merlin','diamond',
      'computer','internet','samsung','google','pokemon','minecraft','naruto','asdfghjkl','asdfgh','zxcvbnm',
      'zxcvbn','asdf1234','qwer1234','1q2w3e','112233','445566','159753','147258','741852','963852',
      '102030','123321','7777777','88888888','999999','555555','333333','777777','11111111','88888',
      'purple','orange','yellow','banana','apple','cheese','chocolate','flower','angel','lovely',
      'beautiful','forever','friends','family','money','iloveu','loveme','lovers','mylove','babygirl',
      'angels','spider','tigger','snoopy','mickey','bailey','chelsea','arsenal','liverpool','barcelona',
      'realmadrid','america','mexico','espana','madrid','sevilla','valencia','andres','antonio','alberto',
      'alejandro','alejandra','fernando','francisco','gabriel','ricardo','roberto','eduardo','cristian','sebastian',
      'santiago','mariana','valeria','daniela','gabriela','fernanda','alexandra','estrella','mariposa','princesa',
      'corazon','tequiero','teamo','hola123','holahola','futbol','beisbol','flores','amistad','familia',
      'amorcito','hermosa','preciosa','carino','angelito','diablo','metallica','nirvana','eminem','shakira',
      'abcdef','abcd1234','a123456','123qwe','qwe123','1234qwer','q1w2e3r4','zaq1zaq1','p@ssw0rd','passw0rd',
      'pa55word','letmein1','welcome1','admin123','root123','test123','pass123','demo123','iloveyou1','sunshine1',
      'monkey1','dragon1','qwerty1','michael1','superman1','babygurl','bonita','pelota','tortuga','caballo',
    ]);

    const KEY_ROWS = ['qwertyuiop', 'asdfghjkl', 'zxcvbnm'];

    function isSequential(text: string): boolean {
      for (let i = 0; i + 2 < text.length; i++) {
        const a = text.charCodeAt(i);
        const b = text.charCodeAt(i + 1);
        const c = text.charCodeAt(i + 2);
        const alnum = /[a-z0-9]/.test(text[i]!) && /[a-z0-9]/.test(text[i + 1]!) && /[a-z0-9]/.test(text[i + 2]!);
        if (alnum && ((b === a + 1 && c === b + 1) || (b === a - 1 && c === b - 1))) return true;
      }
      return false;
    }

    function hasKeyboardPattern(lower: string): boolean {
      for (let i = 0; i + 3 < lower.length; i++) {
        const window = lower.slice(i, i + 4);
        const reversed = [...window].reverse().join('');
        if (KEY_ROWS.some((row) => row.includes(window) || row.includes(reversed))) return true;
      }
      return false;
    }

    // Undo common leetspeak substitutions and trailing digits so that
    // "P@ssw0rd1" is recognized as a variant of "password".
    function variants(lower: string): string[] {
      const leetBase = lower.replace(/@|4/g, 'a').replace(/0/g, 'o').replace(/3/g, 'e')
        .replace(/\$|5/g, 's').replace(/7/g, 't').replace(/8/g, 'b').replace(/!/g, 'i');
      const out = new Set<string>();
      for (const leet of [leetBase.replace(/1/g, 'i'), leetBase.replace(/1/g, 'l'), lower]) {
        out.add(leet);
        out.add(leet.replace(/[\d!@#$%^&*.?]+$/, ''));
      }
      out.delete(lower);
      out.delete('');
      return [...out];
    }

    function formatTime(seconds: number): string {
      const d = root!.dataset;
      const fmt = (template: string, n: number) => template.replace('{n}', String(n));
      if (seconds < 1) return d.tInstant!;
      if (seconds < 60) return fmt(d.tSeconds!, Math.round(seconds));
      if (seconds < 3600) return fmt(d.tMinutes!, Math.round(seconds / 60));
      if (seconds < 86400) return fmt(d.tHours!, Math.round(seconds / 3600));
      if (seconds < 86400 * 365) return fmt(d.tDays!, Math.round(seconds / 86400));
      const years = seconds / (86400 * 365);
      if (years < 100) return fmt(d.tYears!, Math.round(years));
      return d.tCenturies!;
    }

    const METER = [
      { cls: 'bg-red-500', width: '10%' },
      { cls: 'bg-red-400', width: '30%' },
      { cls: 'bg-amber-400', width: '55%' },
      { cls: 'bg-brand-cyan', width: '80%' },
      { cls: 'bg-gradient-to-r from-brand-magenta to-brand-cyan', width: '100%' },
    ];

    function setCheck(id: string, met: boolean) {
      const item = $(id);
      const mark = item.querySelector('.ps-mark')!;
      mark.textContent = met ? '✓' : '✗';
      item.className = `flex items-center gap-2 text-sm ${met ? 'text-emerald-400' : 'text-brand-muted'}`;
    }

    function analyze() {
      const pw = input.value;
      if (!pw) {
        results.classList.add('hidden');
        return;
      }
      results.classList.remove('hidden');

      const hasLower = /[a-z]/.test(pw);
      const hasUpper = /[A-Z]/.test(pw);
      const hasDigit = /[0-9]/.test(pw);
      const hasSymbol = /[^A-Za-z0-9]/.test(pw);
      setCheck('ps-chk-lower', hasLower);
      setCheck('ps-chk-upper', hasUpper);
      setCheck('ps-chk-digit', hasDigit);
      setCheck('ps-chk-symbol', hasSymbol);
      setCheck('ps-chk-length', pw.length >= 12);

      const pool = (hasLower ? 26 : 0) + (hasUpper ? 26 : 0) + (hasDigit ? 10 : 0) + (hasSymbol ? 33 : 0);
      let bits = pw.length * Math.log2(pool || 1);

      const lower = pw.toLowerCase();
      const warnings: { key: string; critical: boolean }[] = [];
      const isCommon = COMMON.has(lower);
      const isVariant = !isCommon && variants(lower).some((v) => COMMON.has(v));
      if (isCommon) warnings.push({ key: 'wCommon', critical: true });
      if (isVariant) warnings.push({ key: 'wVariant', critical: true });
      if (isSequential(lower)) warnings.push({ key: 'wSeq', critical: false });
      if (/(.)\1\1/.test(pw)) warnings.push({ key: 'wRep', critical: false });
      if (hasKeyboardPattern(lower)) warnings.push({ key: 'wKey', critical: false });

      if (isCommon) bits = Math.min(bits, 8);
      else if (isVariant) bits = Math.min(bits, 24);
      else {
        for (const w of warnings) bits -= w.key === 'wKey' ? 12 : 8;
        bits = Math.max(bits, 1);
      }

      const level = bits < 28 ? 0 : bits < 40 ? 1 : bits < 65 ? 2 : bits < 100 ? 3 : 4;
      meter.className = 'h-full rounded-full transition-all duration-300 ' + METER[level]!.cls;
      meter.style.width = METER[level]!.width;
      ratingEl.textContent = `${root!.dataset['r' + level]} (~${Math.round(bits)} bits)`;
      timeEl.textContent = formatTime(2 ** (bits - 1) / 1e10);

      warningsEl.textContent = '';
      for (const w of warnings) {
        const li = document.createElement('li');
        li.className = w.critical ? 'text-red-400' : 'text-amber-400';
        li.textContent = '⚠ ' + root!.dataset[w.key]!;
        warningsEl.appendChild(li);
      }
      warningsEl.classList.toggle('hidden', warnings.length === 0);
    }

    toggle.addEventListener('click', () => {
      const showing = input.type === 'text';
      input.type = showing ? 'password' : 'text';
      toggle.textContent = showing ? root.dataset.labelShow! : root.dataset.labelHide!;
    });
    input.addEventListener('input', analyze);
  }
</script>
