---
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-brand-border bg-brand-surface/60">
  <div class="mx-auto max-w-5xl px-4 py-8 text-sm text-brand-muted">
    <p class="mb-2">{t('footer.privacy')}</p>
    <div class="flex flex-wrap items-center gap-x-4 gap-y-1">
      <span>© {year} {t('footer.builtBy')}</span>
      <a
        href="https://yongchivo.com"
        target="_blank"
        rel="noopener"
        class="transition-colors hover:text-brand-cyan"
      >
        {t('nav.yongchivo')}
      </a>
      <a
        href="https://yongchivo.com/phv-prep-uk"
        target="_blank"
        rel="noopener"
        class="transition-colors hover:text-brand-cyan"
      >
        {t('nav.phvprep')}
      </a>
    </div>
  </div>
</footer>
