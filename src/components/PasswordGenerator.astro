---
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div
  id="pwgen"
  class="max-w-2xl rounded-xl border border-brand-border bg-brand-surface p-5 sm:p-6"
  data-label-copy={t('pwgen.copy')}
  data-label-copied={t('pwgen.copied')}
  data-label-weak={t('pwgen.weak')}
  data-label-medium={t('pwgen.medium')}
  data-label-strong={t('pwgen.strong')}
  data-label-very-strong={t('pwgen.veryStrong')}
>
  <div class="flex flex-col gap-2 sm:flex-row">
    <input
      id="pw-output"
      type="text"
      readonly
      aria-label={t('pwgen.outputLabel')}
      autocomplete="off"
      spellcheck="false"
      class="min-w-0 flex-1 rounded-lg border border-brand-border bg-brand-bg px-3 py-2.5 font-mono text-sm text-brand-cyan focus:border-brand-purple focus:outline-none"
    />
    <div class="flex gap-2">
      <button
        id="pw-copy"
        type="button"
        class="flex-1 rounded-lg border border-brand-purple/40 bg-brand-purple/20 px-4 py-2.5 text-sm font-medium text-brand-purple transition-colors hover:bg-brand-purple/30 sm:flex-none"
      >
        {t('pwgen.copy')}
      </button>
      <button
        id="pw-regenerate"
        type="button"
        class="flex-1 rounded-lg border border-brand-border px-4 py-2.5 text-sm font-medium text-brand-muted transition-colors hover:border-brand-cyan/60 hover:text-brand-cyan sm:flex-none"
      >
        {t('pwgen.regenerate')}
      </button>
    </div>
  </div>

  <div class="mt-4">
    <div class="h-1.5 overflow-hidden rounded-full bg-brand-border">
      <div id="pw-meter" class="h-full rounded-full transition-all duration-300"></div>
    </div>
    <p class="mt-1.5 text-xs text-brand-muted">
      {t('pwgen.strengthLabel')}: <span id="pw-strength" class="font-medium text-brand-text"></span>
    </p>
  </div>

  <div class="mt-6 border-t border-brand-border pt-5">
    <label for="pw-length" class="flex items-center justify-between text-sm">
      <span>{t('pwgen.length')}</span>
      <span id="pw-length-value" class="font-mono text-brand-cyan">16</span>
    </label>
    <input id="pw-length" type="range" min="8" max="64" value="16" class="mt-2 w-full accent-brand-purple" />

    <div class="mt-5 grid gap-3 sm:grid-cols-2">
      <label class="flex items-center gap-2.5 text-sm">
        <input id="pw-upper" type="checkbox" checked class="h-4 w-4 accent-brand-purple" />
        {t('pwgen.uppercase')}
      </label>
      <label class="flex items-center gap-2.5 text-sm">
        <input id="pw-lower" type="checkbox" checked class="h-4 w-4 accent-brand-purple" />
        {t('pwgen.lowercase')}
      </label>
      <label class="flex items-center gap-2.5 text-sm">
        <input id="pw-numbers" type="checkbox" checked class="h-4 w-4 accent-brand-purple" />
        {t('pwgen.numbers')}
      </label>
      <label class="flex items-center gap-2.5 text-sm">
        <input id="pw-symbols" type="checkbox" checked class="h-4 w-4 accent-brand-purple" />
        {t('pwgen.symbols')}
      </label>
      <label class="flex items-center gap-2.5 text-sm sm:col-span-2">
        <input id="pw-ambiguous" type="checkbox" class="h-4 w-4 accent-brand-purple" />
        {t('pwgen.excludeAmbiguous')}
      </label>
    </div>
  </div>
</div>

<script>
  const root = document.getElementById('pwgen');
  if (root) {
    const output = document.getElementById('pw-output') as HTMLInputElement;
    const copyBtn = document.getElementById('pw-copy') as HTMLButtonElement;
    const regenBtn = document.getElementById('pw-regenerate') as HTMLButtonElement;
    const lengthInput = document.getElementById('pw-length') as HTMLInputElement;
    const lengthValue = document.getElementById('pw-length-value') as HTMLElement;
    const meter = document.getElementById('pw-meter') as HTMLElement;
    const strengthText = document.getElementById('pw-strength') as HTMLElement;
    const ambiguous = document.getElementById('pw-ambiguous') as HTMLInputElement;
    const typeBoxes = ['pw-upper', 'pw-lower', 'pw-numbers', 'pw-symbols'].map(
      (id) => document.getElementById(id) as HTMLInputElement
    );

    const SETS: Record<string, string> = {
      'pw-upper': 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
      'pw-lower': 'abcdefghijklmnopqrstuvwxyz',
      'pw-numbers': '0123456789',
      'pw-symbols': '!@#$%^&*()-_=+[]{};:,.<>?~',
    };
    const AMBIGUOUS = /[lI1O0]/g;

    // Unbiased random int in [0, max) via rejection sampling — modulo alone
    // would skew the distribution for pool sizes that don't divide 2^32.
    function randomInt(max: number): number {
      const buf = new Uint32Array(1);
      const limit = 0x100000000 - (0x100000000 % max);
      do {
        crypto.getRandomValues(buf);
      } while (buf[0]! >= limit);
      return buf[0]! % max;
    }

    function activeSets(): string[] {
      return typeBoxes
        .filter((box) => box.checked)
        .map((box) => (ambiguous.checked ? SETS[box.id]!.replace(AMBIGUOUS, '') : SETS[box.id]!));
    }

    const LEVELS = [
      { max: 40, key: 'labelWeak', cls: 'bg-red-400', width: '25%' },
      { max: 65, key: 'labelMedium', cls: 'bg-amber-400', width: '50%' },
      { max: 100, key: 'labelStrong', cls: 'bg-brand-cyan', width: '75%' },
      {
        max: Infinity,
        key: 'labelVeryStrong',
        cls: 'bg-gradient-to-r from-brand-magenta to-brand-cyan',
        width: '100%',
      },
    ];

    function updateStrength(length: number, poolSize: number) {
      const bits = Math.round(length * Math.log2(poolSize));
      const level = LEVELS.find((l) => bits < l.max)!;
      meter.className = 'h-full rounded-full transition-all duration-300 ' + level.cls;
      meter.style.width = level.width;
      strengthText.textContent = `${root!.dataset[level.key]} (~${bits} bits)`;
    }

    function generate() {
      const sets = activeSets();
      if (!sets.length) return;
      const pool = sets.join('');
      const length = Math.min(64, Math.max(8, Number(lengthInput.value) || 16));
      // Guarantee at least one character from each selected set, fill the
      // rest from the combined pool, then shuffle so positions are random.
      const chars = sets.map((set) => set[randomInt(set.length)]!);
      while (chars.length < length) chars.push(pool[randomInt(pool.length)]!);
      for (let i = chars.length - 1; i > 0; i--) {
        const j = randomInt(i + 1);
        [chars[i], chars[j]] = [chars[j]!, chars[i]!];
      }
      output.value = chars.join('');
      updateStrength(length, pool.length);
    }

    // The last remaining character-type toggle is disabled so the charset
    // can never become empty.
    function enforceCharsetRule() {
      const checkedCount = typeBoxes.filter((box) => box.checked).length;
      typeBoxes.forEach((box) => {
        box.disabled = checkedCount === 1 && box.checked;
      });
    }

    let copyTimer: ReturnType<typeof setTimeout>;
    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(output.value);
      } catch {
        output.select();
        document.execCommand('copy');
      }
      copyBtn.textContent = root.dataset.labelCopied!;
      clearTimeout(copyTimer);
      copyTimer = setTimeout(() => {
        copyBtn.textContent = root.dataset.labelCopy!;
      }, 1500);
    });

    typeBoxes.forEach((box) =>
      box.addEventListener('change', () => {
        enforceCharsetRule();
        generate();
      })
    );
    ambiguous.addEventListener('change', generate);
    lengthInput.addEventListener('input', () => {
      lengthValue.textContent = lengthInput.value;
      generate();
    });
    regenBtn.addEventListener('click', generate);

    enforceCharsetRule();
    generate();
  }
</script>
