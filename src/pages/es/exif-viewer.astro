---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExifViewer from '../../components/ExifViewer.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import { useTranslations } from '../../i18n/ui';

const lang = 'es';
const t = useTranslations(lang);
---

<BaseLayout lang={lang} title={t('exif.title')} description={t('exif.metaDescription')}>
  <section class="mb-8 max-w-2xl">
    <h1 class="mb-3 text-3xl font-bold tracking-tight sm:text-4xl">
      <span
        class="bg-gradient-to-r from-brand-magenta via-brand-purple to-brand-cyan bg-clip-text text-transparent"
      >
        {t('exif.heading')}
      </span>
    </h1>
    <p class="text-brand-muted">{t('exif.intro')}</p>
  </section>

  <ExifViewer lang={lang} />

  <RelatedTools lang={lang} slugs={['pdf-metadata', 'breach-check', 'password-strength']} />
</BaseLayout>
