---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PdfMetadataEditor from '../../components/PdfMetadataEditor.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import { useTranslations } from '../../i18n/ui';

const lang = 'es';
const t = useTranslations(lang);
---

<BaseLayout lang={lang} title={t('pdf.title')} description={t('pdf.metaDescription')}>
  <section class="mb-8 max-w-2xl">
    <h1 class="mb-3 text-3xl font-bold tracking-tight sm:text-4xl">
      <span
        class="bg-gradient-to-r from-brand-magenta via-brand-purple to-brand-cyan bg-clip-text text-transparent"
      >
        {t('pdf.heading')}
      </span>
    </h1>
    <p class="text-brand-muted">{t('pdf.intro')}</p>
  </section>

  <PdfMetadataEditor lang={lang} />

  <RelatedTools lang={lang} slugs={['exif-viewer', 'breach-check', 'security-headers']} />
</BaseLayout>
