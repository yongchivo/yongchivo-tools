---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SecurityHeadersChecker from '../../components/SecurityHeadersChecker.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import { useTranslations } from '../../i18n/ui';

const lang = 'es';
const t = useTranslations(lang);
---

<BaseLayout lang={lang} title={t('sh.title')} description={t('sh.metaDescription')}>
  <section class="mb-8 max-w-2xl">
    <h1 class="mb-3 text-3xl font-bold tracking-tight sm:text-4xl">
      <span
        class="bg-gradient-to-r from-brand-magenta via-brand-purple to-brand-cyan bg-clip-text text-transparent"
      >
        {t('sh.heading')}
      </span>
    </h1>
    <p class="text-brand-muted">{t('sh.intro')}</p>
  </section>

  <SecurityHeadersChecker lang={lang} />

  <RelatedTools lang={lang} slugs={['password-strength', 'breach-check']} />
</BaseLayout>
